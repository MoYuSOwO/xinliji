---
import BaseLayout from "../layouts/BaseLayout.astro";
import Library from "../components/Library.astro";
import Masthead from "../components/Masthead.astro";
import { articleUrl, getSortedArticles, getVolumes, volumeName } from "../lib/articles";

const articles = await getSortedArticles();
const allVolumes = getVolumes();
const volumes = allVolumes.filter((volume) => articles.some((article) => article.data.volumeId === volume.id));
const volumeTotal = allVolumes.length;
const introArticle = articles.find((article) => article.data.volumeId === 0) || articles[0];
const recentArticles = [...articles]
  .sort((a, b) => String(b.data.date || "").localeCompare(String(a.data.date || "")) || a.data.title.localeCompare(b.data.title, "zh-Hans"))
  .slice(0, 4);

const volumeDescriptions = new Map([
  [0, "册首缘起，说明今事何以入古书。"],
  [1, "情绪、自控、成长、学习、身体与心性。"],
  [2, "亲子、家庭、婚恋、代际、亲情与人伦。"],
  [3, "学校、考试、导师、职场、老板与同事。"],
  [4, "钱财、消费、购物、订阅、贫富与交易。"],
  [5, "技术、AI、编程、工程、器物、车与工具。"],
  [6, "网梗、舆论、争议、社会怪象与评论区。"],
]);
const volumeItems = allVolumes.map((volume) => {
  const entries = articles.filter((article) => article.data.volumeId === volume.id);
  return {
    ...volume,
    count: entries.length,
    description: volumeDescriptions.get(volume.id) || "",
  };
});
---

<BaseLayout title="新礼记">
  <Masthead totalCount={articles.length} volumeCount={volumeTotal} />

  <main id="mainContent" class="home-main" tabindex="-1">
    <section class="home-cover" aria-labelledby="homeCoverTitle">
      <div class="home-cover-copy">
        <p class="eyebrow">册首</p>
        <h2 id="homeCoverTitle">今事入古书</h2>
        <p>
          《新礼记》收录网络梗、评论区公案与日常小事，取《世说》一类轻文言笔法，写成人情、机锋与余味并在的小品。
        </p>
        <div class="home-actions" aria-label="首页入口">
          <a class="text-button text-button-primary" href="#catalog">入目录</a>
          {introArticle && <a class="text-button" href={articleUrl(introArticle)}>读序</a>}
        </div>
      </div>

      <aside class="home-recent" aria-labelledby="recentTitle">
        <p class="eyebrow">近收</p>
        <h3 id="recentTitle">新入诸篇</h3>
        <div class="home-recent-list">
          {
            recentArticles.map((article) => (
              <a class="recent-link" href={articleUrl(article)}>
                <span>{article.data.title}</span>
                <small>{volumeName(article)} · {article.data.date}</small>
              </a>
            ))
          }
        </div>
      </aside>
    </section>

    <section class="archive-note" aria-labelledby="archiveNoteTitle">
      <div>
        <p class="eyebrow">凡例</p>
        <h2 id="archiveNoteTitle">入藏说明</h2>
      </div>
      <p>本站无后台，诸篇皆藏于 GitHub。若有增删校勘，构建刊行，可至原库提 PR。</p>
      <a class="note-link" href="https://github.com/MoYuSOwO/xinliji" target="_blank" rel="noreferrer" aria-label="打开 GitHub 仓库 MoYuSOwO/xinliji">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M12 .5a12 12 0 0 0-3.8 23.38c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.6-4.04-1.6-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.08 1.83 2.82 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.66-.31-5.46-1.34-5.46-5.94 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.4 11.4 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.62-2.8 5.62-5.48 5.92.43.37.82 1.1.82 2.23v3.29c0 .32.21.7.83.58A12 12 0 0 0 12 .5Z"></path>
        </svg>
        原库提 PR
      </a>
    </section>

    <section class="volume-section" aria-labelledby="volumeTitle">
      <div class="section-heading">
        <div>
          <p class="eyebrow">卷目</p>
          <h2 id="volumeTitle">六卷一序</h2>
        </div>
        <a class="section-link" href="#catalog">全部篇目</a>
      </div>
      <div class="volume-grid">
        {
          volumeItems.map((volume) => (
            volume.count > 0 ? (
              <a class="volume-card" href="#catalog" data-volume-shortcut={String(volume.id)}>
                <span class="volume-card-kicker">{volume.name}</span>
                <span class="volume-card-count">{volume.count} 篇</span>
                <p>{volume.description}</p>
              </a>
            ) : (
              <div class="volume-card is-empty" aria-disabled="true">
                <span class="volume-card-kicker">{volume.name}</span>
                <span class="volume-card-count">待收</span>
                <p>{volume.description}</p>
              </div>
            )
          ))
        }
      </div>
    </section>

    <section id="catalog" class="catalog-section" aria-labelledby="catalogTitle">
      <div class="section-heading">
        <div>
          <p class="eyebrow">目录</p>
          <h2 id="catalogTitle">检索诸篇</h2>
        </div>
      </div>
      <Library articles={articles} volumes={volumes} />
    </section>
  </main>

  <script>
    import "../scripts/library.js";
  </script>
</BaseLayout>
