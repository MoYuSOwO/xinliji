---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Library from "../components/Library.astro";
import Masthead from "../components/Masthead.astro";
import {
  articleUrl,
  countCjkLikeChars,
  getSortedArticles,
  getVolumes,
  readerPositionText,
  volumeName,
} from "../lib/articles";

const articles = await getSortedArticles();
const volumes = getVolumes().filter((volume) => articles.some((article) => article.data.volumeId === volume.id));
const first = articles[0];
const second = articles[1];
const { Content } = await render(first);
const charCount = countCjkLikeChars(first.body || "");
---

<BaseLayout title="新礼记">
  <Masthead totalCount={articles.length} volumeCount={volumes.length} />

  <main id="mainContent" class="layout">
    <Library articles={articles} volumes={volumes} currentSlug={first.id} />

    <article id="readerPanel" class="reader" tabindex="-1">
      <div class="reader-inner">
        <div class="reader-top">
          <div>
            <p class="volume">{volumeName(first)}</p>
            <p class="reader-count">
              {readerPositionText(0, articles.length)} · {charCount}字
            </p>
          </div>
        </div>
        <h2>{first.data.title}</h2>
        <div class="meta-line">
          {[first.data.date, first.data.author ? `作者：${first.data.author}` : ""].filter(Boolean).join(" · ")}
        </div>
        <nav class="reader-actions" aria-label="篇目翻阅">
          <span class="text-button is-disabled" aria-disabled="true">上一篇</span>
          <a class="text-button text-button-primary" href={articleUrl(first)}>本篇页</a>
          {second ? <a class="text-button" href={articleUrl(second)}>下一篇</a> : <span class="text-button is-disabled" aria-disabled="true">下一篇</span>}
        </nav>
        <div class="article-body">
          <Content />
        </div>
      </div>
    </article>
  </main>

  <script>
    import "../scripts/library.js";
  </script>
</BaseLayout>
